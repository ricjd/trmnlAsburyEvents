{% comment %}
  Half vertical layout (400x480) — paste into the "Half vertical" tab.
  Same structure as Full, just narrower — rows will wrap more.
{% endcomment %}
<div class="layout">
  <div class="columns">
    <div class="column">
      {% if days and days.size > 0 %}
        {% for day in days %}
          <div class="item item--emphasis-2">
            <div class="content">
              <span class="title title--small">{{ day.label }} &middot; {{ day.date }}</span>
            </div>
          </div>
          {% for e in day.events %}
            <div class="item">
              <div class="meta">
                <span class="label label--small">{{ e.time }}</span>
              </div>
              <div class="content">
                <span class="title title--small">{{ e.title }}</span>
              </div>
            </div>
          {% endfor %}
        {% endfor %}
      {% else %}
        <span class="label">No upcoming events.</span>
      {% endif %}
    </div>
  </div>
</div>

<div class="title_bar">
  <span class="title">Beach House</span>
</div>
